Output demos/bootstrap.gif

Require pi
Require npm

Set Shell "bash"
Set FontFamily "Fira Code Retina"
Set FontSize 24
Set Width 1440
Set Height 1080
Set TypingSpeed 55ms

Hide
Type "./scripts/pi.sh --home tmp/pihome --cd tmp/work --clear"
Enter
Sleep 3000ms
Show

Sleep 1800ms

Sleep 1400ms
Type "/plu"
Sleep 170ms
Tab
Sleep 170ms
Type "boot"
Sleep 170ms
Tab
Sleep 1800ms
Enter

Sleep 1800ms

Sleep 1400ms
Type "/plu"
Sleep 170ms
Tab
Sleep 170ms
Type "ls"
Sleep 170ms
Tab
Sleep 170ms
Type "--a"
Sleep 170ms
Tab
Sleep 1800ms
Enter

Sleep 1800ms
Type "/plu"
Sleep 170ms
Tab
Sleep 170ms
Type "i"
Sleep 170ms
Tab
Sleep 170ms
Type "pr-"
Sleep 170ms
Tab
Sleep 1800ms
Enter

Sleep 1400ms

Type "/reload"
Sleep 1800ms
Enter

Sleep 1400ms

Sleep 1400ms
Type "/plu"
Sleep 170ms
Tab
Sleep 170ms
Type "ls"
Sleep 170ms
Tab
Sleep 170ms
Type "--i"
Sleep 170ms
Tab
Sleep 1800ms
Enter

Sleep 1800ms

Type "/pr-"
Sleep 170ms
Tab
Sleep 1800ms
Enter

Sleep 5s

Hide
Type "/claude:plugin marketplace rm anthropics/claude-plugins-official"
Sleep 500ms
Ctrl+C
